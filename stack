#!/usr/bin/env node
// Stack — the `stack` CLI dispatcher. Subcommands live in scripts/ as ESM;
// this file is extensionless (so CommonJS — there is no root package.json)
// and reaches them via dynamic import, resolved relative to this file so it
// works from any working directory (or symlinked onto PATH).
//
//   stack tree [--repo <path>] [--json]   the branch navigator
//   stack help
const { join } = require('node:path');
const { pathToFileURL } = require('node:url');

const COMMANDS = {
  tree: { script: 'stack-tree.mjs', blurb: 'render the branch navigator tree' },
};

const [cmd, ...rest] = process.argv.slice(2);

function usage(code) {
  const lines = ['usage: stack <command> [options]', ''];
  for (const [name, { blurb }] of Object.entries(COMMANDS)) lines.push(`  ${name.padEnd(8)} ${blurb}`);
  (code ? process.stderr : process.stdout).write(lines.join('\n') + '\n');
  process.exit(code);
}

if (!cmd || cmd === 'help' || cmd === '--help' || cmd === '-h') usage(0);
if (!COMMANDS[cmd]) {
  process.stderr.write(`[stack] unknown command: ${cmd}\n\n`);
  usage(1);
}

import(pathToFileURL(join(__dirname, 'scripts', COMMANDS[cmd].script)).href)
  .then((m) => process.exit(m.main(rest)))
  .catch((e) => {
    process.stderr.write(`[stack] ${cmd} failed: ${e.message}\n`);
    process.exit(1);
  });
